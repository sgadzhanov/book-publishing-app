generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  EDITOR
  ADMIN
}

enum DeliveryMode {
  PHYSICAL
  DIGITAL
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
  EXPIRED
}

enum FulfillmentStatus {
  NOT_REQUIRED
  PENDING
  PROCESSING
  FULFILLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Order {
  id                      String             @id @default(cuid())
  userId                  String?
  email                   String
  customerName            String?
  status                  OrderStatus        @default(PENDING)
  fulfillmentStatus       FulfillmentStatus  @default(PENDING)
  deliveryMode            DeliveryMode
  currency                String             @default("eur")
  subtotalAmount          Int
  totalAmount             Int
  locale                  String
  stripeCheckoutSessionId String?            @unique
  stripePaymentIntentId   String?
  shippingAddress         Json?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  user                    User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  items                   OrderItem[]
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  sanityBookId  String?
  bookSlug      String
  bookLocale    String
  title         String
  authorName    String?
  coverImageUrl String?
  quantity      Int          @default(1)
  unitAmount    Int
  currency      String       @default("eur")
  deliveryMode  DeliveryMode
  downloadUrl   String?
  createdAt     DateTime     @default(now())
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
